user_agent: "threat-brief/1.0 (contact: your-email@example.com)"

llm:
  endpoint: "http://localhost:1234/v1"
  model: "local-model"
  max_tokens: 4096
  temperature: 0.3

sources:
  apple_security:
    enabled: true
    url: "https://support.apple.com/en-us/100100"
    fetch_details: true   # Fetch individual release pages for CVE counts and impact descriptions
    group_by_date: true   # Consolidate same-day releases (iOS + macOS + watchOS etc.) into one item
  cisa_advisories:
    enabled: true
    url: "https://www.cisa.gov/cybersecurity-advisories/all.xml"
  cisa_kev:
    enabled: true
    url: "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json"
  msrc:
    enabled: true
    url: "https://api.msrc.microsoft.com/cvrf/v3.0/updates"
  aws_security:
    enabled: true
    url: "https://aws.amazon.com/security/security-bulletins/"
  hackernews_threatintel:
    enabled: true
    url: "https://feeds.feedburner.com/TheHackersNews"
  krebs:
    enabled: true
    url: "https://krebsonsecurity.com/feed/"
  isc_sans:
    enabled: true
    url: "https://isc.sans.edu/rssfeed_full.xml"
    infocon_url: "https://isc.sans.edu/infocon.txt"
  mandiant:
    enabled: true
    url: "https://feeds.feedburner.com/threatintelligence/pvexyqv7v0v"

# Optional — run `threat-brief init` to configure interactively
# org_profile:
#   company_name: "Your Company"
#   industry:
#     - "Financial Services"
#   tech_stack:
#     operating_systems:
#       - "Windows 11"
#       - "macOS"
#     infrastructure:
#       - "Active Directory"
#       - "AWS"
#     applications:
#       - "Microsoft 365"
#     languages_and_frameworks:
#       - "Python"
#     security_tools:
#       - "CrowdStrike Falcon"

reports_dir: "./reports"
default_hours: 48

settings:
  # Tag items not seen in the previous run with a [NEW] badge.
  # Use --diff / --no-diff at the CLI to override for a single run.
  flag_new_items: true
